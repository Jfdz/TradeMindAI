# ============================================================================
# Trading SaaS - Environment Variables
# ============================================================================
# Copy this file to .env and update values for your environment.
# Never commit .env to version control (it's in .gitignore).
# ============================================================================

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development
DEBUG=true

# ============================================================================
# Database - PostgreSQL
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=dev_password_change_in_prod
POSTGRES_DB=trading_saas

# Schemas (one per service)
# market_data_schema=market_data
# trading_core_schema=trading_core
# ai_engine_schema=ai_engine

# ============================================================================
# Redis
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache TTLs (seconds)
REDIS_TTL_LATEST_PRICES=300
REDIS_TTL_HISTORICAL_DATA=3600
REDIS_TTL_USER_SESSIONS=900

# ============================================================================
# RabbitMQ
# ============================================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ============================================================================
# Services - Ports
# ============================================================================
MARKET_DATA_SERVICE_PORT=8081
TRADING_CORE_SERVICE_PORT=8082
AI_ENGINE_SERVICE_PORT=8000
WEB_APP_PORT=3000

# ============================================================================
# Services - URLs (for service-to-service communication)
# ============================================================================
MARKET_DATA_SERVICE_URL=http://market-data-service:8081
TRADING_CORE_SERVICE_URL=http://trading-core-service:8082
AI_ENGINE_SERVICE_URL=http://ai-engine:8000
WEB_APP_URL=http://web-app:3000

# For local development without Docker
LOCAL_MARKET_DATA_SERVICE_URL=http://localhost:8081
LOCAL_TRADING_CORE_SERVICE_URL=http://localhost:8082
LOCAL_AI_ENGINE_SERVICE_URL=http://localhost:8000
LOCAL_WEB_APP_URL=http://localhost:3000

# ============================================================================
# Authentication & Security
# ============================================================================
# JWT Configuration
JWT_SECRET=dev-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# Session/Cookie
SESSION_SECRET=dev-session-secret-change-in-production
SECURE_COOKIES=false
SAME_SITE=lax

# ============================================================================
# Market Data Service Configuration
# ============================================================================
# Data Source
MARKET_DATA_SOURCE=yahoo_finance
STOCK_SYMBOLS=AAPL,MSFT,GOOGL,TSLA,AMZN,NVDA,META,AMD

# Data Ingestion
DATA_INGESTION_BATCH_SIZE=50
DATA_INGESTION_INTERVAL_MINUTES=5
DATA_INGESTION_TIMEOUT_SECONDS=30

# Technical Indicators
INCLUDE_TECHNICAL_INDICATORS=true
INDICATOR_LOOKBACK_PERIODS=20,50,200

# ============================================================================
# AI Engine Configuration
# ============================================================================
# Model Configuration
MODEL_TYPE=cnn
MODEL_PATH=./models/trading_model.pt
MODEL_BATCH_SIZE=32

# Inference
INFERENCE_TIMEOUT_SECONDS=5
ENABLE_GPU=false
GPU_DEVICE_ID=0

# Training (if applicable)
TRAINING_BATCH_SIZE=64
TRAINING_EPOCHS=50
TRAINING_LEARNING_RATE=0.001

# ============================================================================
# Trading Core Service Configuration
# ============================================================================
# Strategy Configuration
DEFAULT_STRATEGY_LEVERAGE=1.0
MAX_STRATEGY_LEVERAGE=3.0
MIN_STOP_LOSS_PCT=0.5
MAX_STOP_LOSS_PCT=10.0
MIN_TAKE_PROFIT_PCT=1.0
MAX_TAKE_PROFIT_PCT=50.0

# Risk Management
MAX_POSITION_SIZE_PCT=5.0
MAX_DAILY_LOSS_PCT=2.0
POSITION_HOLD_TIME_MINUTES=1440

# ============================================================================
# Backtesting Configuration
# ============================================================================
BACKTEST_MAX_DURATION_DAYS=365
BACKTEST_MIN_HISTORICAL_DATA_DAYS=252
BACKTEST_SLIPPAGE_BPS=10
BACKTEST_COMMISSION_BPS=5

# ============================================================================
# API Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
# Per subscription tier (requests per minute)
RATE_LIMIT_FREE=30
RATE_LIMIT_PREMIUM=300
RATE_LIMIT_ENTERPRISE=unlimited

# ============================================================================
# Email & Notifications
# ============================================================================
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@tradingsaas.com
SMTP_PASSWORD=
SMTP_FROM=noreply@tradingsaas.com

# Notifications
SLACK_WEBHOOK_URL=
SLACK_ENABLED=false

# ============================================================================
# External APIs
# ============================================================================
# Yahoo Finance API (for market data)
YAHOO_FINANCE_API_KEY=

# Alpha Vantage (alternative market data)
ALPHA_VANTAGE_API_KEY=

# ============================================================================
# Logging & Monitoring
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true
ENABLE_QUERY_LOGGING=false

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_BACKTESTING_ENABLED=true
FEATURE_PAPER_TRADING_ENABLED=true
FEATURE_LIVE_TRADING_ENABLED=false
FEATURE_AI_PREDICTIONS_ENABLED=true

# ============================================================================
# Flyway Database Migrations (Java Services)
# ============================================================================
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_OUT_OF_ORDER=false

# ============================================================================
# Next.js Specific
# ============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8082
NEXT_PUBLIC_APP_NAME=TradeMindAI
NEXT_PUBLIC_APP_VERSION=0.1.0
# NextAuth.js (required for session signing — generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# Jira Integration (scripts/jira-sync.py, scripts/jira-update-status.py)
# ============================================================================
# Jira instance URL (e.g. https://yourcompany.atlassian.net)
JIRA_URL=
# Jira account email
JIRA_EMAIL=
# API token from https://id.atlassian.net/manage-profile/security/api-tokens
JIRA_API_TOKEN=
# Project key (e.g. SCRUM, TRADE)
JIRA_PROJECT=
# Board ID for sprint management (auto-detected if omitted)
JIRA_BOARD_ID=

# ============================================================================
# Production (docker-compose.prod.yml)
# ============================================================================
# Container registry base URL (e.g. registry.example.com or ghcr.io/org)
REGISTRY_URL=
# Image tag to deploy (e.g. v1.0.0 or a git SHA)
IMAGE_TAG=latest
# Public API base URL visible from the browser
API_BASE_URL=https://api.example.com
